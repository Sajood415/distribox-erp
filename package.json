{
  "name": "distribox-erp",
  "version": "1.0.0",
  "description": "Autobiz-style Distribution ERP desktop application",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
  "test": "vitest run",
  "test:watch": "vitest",
  "test:accounting": "vitest run tests/accounting-e2e-verification.test.js",
    "postinstall": "prisma generate --schema prisma/master/schema.prisma && prisma generate --schema prisma/company/schema.prisma",
    "db:migrate:master": "prisma migrate deploy --schema prisma/master/schema.prisma",
    "db:migrate:company": "prisma migrate deploy --schema prisma/company/schema.prisma",
    "db:migrate": "node scripts/migrate-all.js",
    "db:setup": "npm run postinstall && npm run db:migrate",
    "db:migrate:dev:master": "prisma migrate dev --schema prisma/master/schema.prisma",
    "db:migrate:dev:company": "prisma migrate dev --schema prisma/company/schema.prisma",
    "db:studio:master": "prisma studio --schema prisma/master/schema.prisma",
    "db:studio:company": "prisma studio --schema prisma/company/schema.prisma"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "prisma": "^6.19.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.3.0",
    "decimal.js": "^10.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
